DATABASE_URL=postgresql://fleet:fleet@localhost:5432/fleet
PORT=3000
HOST=0.0.0.0
INGEST_TOKEN=
# Temporary: expose POST /api/v1/test/gps/location without auth (default false)
INGEST_OPEN_FOR_TESTING=false
# Auto-create phone-<tid> vehicles on first OwnTracks ingest (default true; set false to reject unknown tids)
AUTO_REGISTER_OWTRACKS_PHONES=true
OFFLINE_THRESHOLD_SEC=300
STATUS_CHECK_INTERVAL_SEC=60
CORS_ORIGINS=http://localhost:5173,http://localhost:8080
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_EXPIRES_IN=7d
# Org used when auto-registering OwnTracks phone devices (set to demo org id after seed)
DEFAULT_ORG_ID=org_demo_fleet
# Shown in Add tracker setup instructions (configure for your deployment)
PUBLIC_AIS140_TCP_HOST=localhost
PUBLIC_AIS140_TCP_PORT=5000
PUBLIC_OWTRACKS_HTTP_URL=http://localhost:3000/api/v1/ingest/owntracks
PUBLIC_OWTRACKS_MQTT_HOST=localhost
PUBLIC_OWTRACKS_MQTT_PORT=1883
# OwnTracks MQTT (optional). Requires OWTRACKS_MQTT_ENABLED=true + docker compose --profile mqtt
OWNTRACKS_MQTT_ENABLED=false
MQTT_URL=mqtt://localhost:1883
OWNTRACKS_MQTT_TOPIC=owntracks/#
AIS140_TCP_ENABLED=true
AIS140_TCP_PORT=5000
AIS140_TCP_HOST=0.0.0.0
AIS140_VALIDATE_CHECKSUM=false
AIS140_SEND_ACK=false
AIS140_DEMO_IMEI=888888888888999

RUN_SEED=true

# Docker Compose profiles (ngrok / adminer)
NGROK_AUTHTOKEN=
# Reserved static ngrok domain (must match domain reserved in ngrok dashboard)
NGROK_DOMAIN=
# Reserved ngrok TCP address for --profile ais140 (paid plan)
NGROK_TCP_ADDRESS=
# Adminer DB UI (dev profile only) — http://localhost:8081
ADMINER_PORT=8081
