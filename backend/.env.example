DATABASE_URL=postgresql://fleet:fleet@localhost:5432/fleet
PORT=3000
HOST=0.0.0.0
INGEST_TOKEN=
OFFLINE_THRESHOLD_SEC=300
STATUS_CHECK_INTERVAL_SEC=60
CORS_ORIGINS=http://localhost:5173,http://localhost:8080
# OwnTracks MQTT (optional). Requires OWTRACKS_MQTT_ENABLED=true + docker compose --profile mqtt
OWNTRACKS_MQTT_ENABLED=false
MQTT_URL=mqtt://localhost:1883
OWNTRACKS_MQTT_TOPIC=owntracks/#
AIS140_TCP_ENABLED=true
AIS140_TCP_PORT=5000
AIS140_TCP_HOST=0.0.0.0
AIS140_VALIDATE_CHECKSUM=false
AIS140_SEND_ACK=false
AIS140_DEMO_IMEI=888888888888999

RUN_SEED=true

# Docker Compose profiles (ngrok / adminer)
NGROK_AUTHTOKEN=
# Reserved static ngrok domain (must match domain reserved in ngrok dashboard)
NGROK_DOMAIN=
# Reserved ngrok TCP address for --profile ais140 (paid plan)
NGROK_TCP_ADDRESS=
# Adminer DB UI (dev profile only) — http://localhost:8081
ADMINER_PORT=8081
