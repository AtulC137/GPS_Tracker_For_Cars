generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Vehicle {
  id            String            @id @default(cuid())
  vehicleName   String
  vehicleNumber String
  deviceId      String            @unique
  createdAt     DateTime          @default(now())
  liveState     VehicleLiveState?
  history       LocationHistory[]
}

model VehicleLiveState {
  vehicleId  String   @id
  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  latitude   Float
  longitude  Float
  speed      Float?
  heading    Float?
  lastSeenAt DateTime
  status     String
}

model LocationHistory {
  id        String   @id @default(cuid())
  vehicleId String
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  latitude  Float
  longitude Float
  speed     Float?
  heading   Float?
  timestamp DateTime
  source    String

  @@index([vehicleId, timestamp])
}
