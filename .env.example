# Backend
INGEST_TOKEN=change-me

# Phone tracking (ngrok) — required when using --profile phone
NGROK_AUTHTOKEN=
# Reserved static ngrok domain (must match domain reserved in ngrok dashboard)
# NGROK_DOMAIN=intense-elf-lively.ngrok-free.app
OFFLINE_THRESHOLD_SEC=300
OWNTRACKS_MQTT_ENABLED=false
CAR_SENSOR_ENABLED=false
RUN_SEED=true

# Frontend build args (browser must reach backend on host, not Docker internal DNS)
VITE_API_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000/ws
