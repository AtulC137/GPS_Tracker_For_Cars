generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  inviteCode  String    @unique
  maxVehicles Int       @default(100)
  createdAt   DateTime  @default(now())
  users       User[]
  vehicles    Vehicle[]
}

model User {
  id             String       @id @default(cuid())
  email          String       @unique
  passwordHash   String
  name           String?
  role           String
  status         String       @default("pending")
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  vehicles       UserVehicle[]

  @@index([organizationId])
}

model Vehicle {
  id             String            @id @default(cuid())
  vehicleName    String
  vehicleNumber  String
  deviceId       String            @unique
  trackerType    String            @default("ais140")
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime          @default(now())
  liveState      VehicleLiveState?
  history        LocationHistory[]
  users          UserVehicle[]

  @@index([organizationId])
}

model UserVehicle {
  userId    String
  vehicleId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@id([userId, vehicleId])
  @@index([vehicleId])
  @@unique([vehicleId])
}

model VehicleLiveState {
  vehicleId  String   @id
  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  latitude   Float
  longitude  Float
  speed      Float?
  heading    Float?
  lastSeenAt DateTime
  status     String
}

model LocationHistory {
  id        String   @id @default(cuid())
  vehicleId String
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  latitude  Float
  longitude Float
  speed     Float?
  heading   Float?
  timestamp DateTime
  source    String

  @@index([vehicleId, timestamp])
}
